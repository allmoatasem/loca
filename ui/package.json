{
  "name": "loca-ui",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Loca's second UI — browser-served, full parity with Loca-SwiftUI (Phase 0 scaffolding)",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "check": "svelte-check --tsconfig ./tsconfig.json",
